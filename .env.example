# Copy this file to `.env` (which is git-ignored) and fill in the keys.
# Tokenizer wrappers read these via os.environ. The count_tokens APIs
# have zero marginal cost (no per-call billing), but Anthropic requires
# a non-zero account balance to access the API at all — a one-time
# minimum top-up at console.anthropic.com (e.g. $5) is required.
# Google's countTokens has a free tier and no balance requirement.

# Anthropic Claude — required for AnthropicTokenizer
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini — required for GoogleTokenizer
# Free tier covers all Phase 1 token counting (no balance requirement).
# Get a key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# HuggingFace Hub — required for gated models (Llama 3.x, etc.).
# Solar / EXAONE / Qwen are open and don't need this token.
# 1) Accept license on the model page (e.g. https://huggingface.co/meta-llama/Llama-3.1-8B-Instruct)
# 2) Create a Read-scoped token at https://huggingface.co/settings/tokens
# `transformers` reads HF_TOKEN automatically; HUGGING_FACE_HUB_TOKEN also works.
HF_TOKEN=

# OpenAI — NOT required for OpenAITokenizer (tiktoken is offline).
# Only set this if you later add inference experiments.
# OPENAI_API_KEY=
